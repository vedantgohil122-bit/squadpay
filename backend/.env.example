# Copy this file to .env and fill in real values. NEVER commit .env.
PORT=5000
CLIENT_URL=http://localhost:5173

# --- OPTION A: local PostgreSQL ---
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/squadpay
DB_SSL=false

# --- OPTION B: Supabase (Project Settings -> Database -> Connection string) ---
# DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
# DB_SSL=true

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
